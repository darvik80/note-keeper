<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="xyz.crearts.note.keeper.mapper.NoteHistoryMapper">

    <resultMap id="historyResultMap" type="xyz.crearts.note.keeper.model.NoteHistory">
        <id property="id" column="id"/>
        <result property="noteId" column="note_id"/>
        <result property="content" column="content"/>
        <result property="timestamp" column="timestamp"/>
        <result property="action" column="action"/>
    </resultMap>

    <insert id="insert" parameterType="xyz.crearts.note.keeper.model.NoteHistory">
        INSERT INTO note_history (id, note_id, content, timestamp, action)
        VALUES (#{id}, #{noteId}, #{content}, #{timestamp}, #{action})
    </insert>

    <select id="findByNoteId" resultMap="historyResultMap" parameterType="String">
        SELECT * FROM note_history WHERE note_id = #{noteId}
        ORDER BY timestamp DESC
    </select>

</mapper>
