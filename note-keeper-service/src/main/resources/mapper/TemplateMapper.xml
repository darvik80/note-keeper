<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="xyz.crearts.note.keeper.mapper.TemplateMapper">

    <resultMap id="templateResultMap" type="xyz.crearts.note.keeper.model.NoteTemplate">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="content" column="content"/>
        <result property="tags" column="tags"
                typeHandler="xyz.crearts.note.keeper.mapper.typehandler.StringListTypeHandler"/>
        <result property="category" column="category"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <select id="findAll" resultMap="templateResultMap">
        SELECT * FROM note_template
        <where>
            <if test="category != null">AND category = #{category}</if>
        </where>
        ORDER BY created_at DESC
    </select>

    <select id="findById" resultMap="templateResultMap" parameterType="String">
        SELECT * FROM note_template WHERE id = #{id}
    </select>

    <insert id="insert" parameterType="xyz.crearts.note.keeper.model.NoteTemplate">
        INSERT INTO note_template (id, name, content, tags, category, created_at)
        VALUES (#{id}, #{name}, #{content},
            #{tags, typeHandler=xyz.crearts.note.keeper.mapper.typehandler.StringListTypeHandler},
            #{category}, #{createdAt})
    </insert>

    <delete id="delete" parameterType="String">
        DELETE FROM note_template WHERE id = #{id}
    </delete>

</mapper>
