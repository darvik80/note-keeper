<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="xyz.crearts.note.keeper.mapper.UserCredentialsMapper">

    <resultMap id="userCredentialsResultMap" type="xyz.crearts.note.keeper.model.UserCredentials">
        <id property="userId" column="user_id"/>
        <result property="passwordHash" column="password_hash"/>
        <result property="salt" column="salt"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <insert id="insert" parameterType="xyz.crearts.note.keeper.model.UserCredentials">
        INSERT INTO user_credentials (user_id, password_hash, salt, created_at, updated_at)
        VALUES (#{userId}, #{passwordHash}, #{salt}, #{createdAt}, #{updatedAt})
    </insert>

    <select id="findByUserId" resultMap="userCredentialsResultMap" parameterType="String">
        SELECT * FROM user_credentials WHERE user_id = #{userId}
    </select>

    <update id="update" parameterType="xyz.crearts.note.keeper.model.UserCredentials">
        UPDATE user_credentials SET
            password_hash = #{passwordHash},
            salt = #{salt},
            updated_at = #{updatedAt}
        WHERE user_id = #{userId}
    </update>

    <delete id="delete" parameterType="String">
        DELETE FROM user_credentials WHERE user_id = #{userId}
    </delete>

</mapper>
