{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "java",
      "name": "NoteKeeper Service",
      "request": "launch",
      "mainClass": "xyz.crearts.note.keeper.NotekeeperApplication",
      "projectName": "note-keeper-service",
      "cwd": "${workspaceFolder}/note-keeper-service",
      "vmArgs": "--enable-native-access=ALL-UNNAMED --sun-misc-unsafe-memory-access=allow -Dio.netty.tryReflectionSetAccessible=true"
    }
  ]
}
